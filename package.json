{
	"name": "n8n-nodes-cobra-cxm",
	"version": "0.1.0",
	"description": "n8n community nodes for cobra CXM WEB CONNECT (cobra Classic) — read, create, update and delete cobra records, search by mail/phone, manage keywords, documents and images.",
	"license": "MIT",
	"homepage": "https://github.com/p17-gmbh/n8n-nodes-cobra-cxm",
	"keywords": [
		"n8n-community-node-package",
		"n8n",
		"cobra",
		"cobra-cxm",
		"webconnect",
		"crm",
		"adressen"
	],
	"author": {
		"name": "p17 GmbH",
		"email": "bb@p17.de"
	},
	"repository": {
		"type": "git",
		"url": "git+https://github.com/p17-gmbh/n8n-nodes-cobra-cxm.git"
	},
	"bugs": {
		"url": "https://github.com/p17-gmbh/n8n-nodes-cobra-cxm/issues"
	},
	"engines": {
		"node": ">=20.19"
	},
	"scripts": {
		"build": "n8n-node build",
		"build:watch": "tsc --watch",
		"dev": "n8n-node dev",
		"lint": "n8n-node lint",
		"lint:fix": "n8n-node lint --fix",
		"test": "node test/smoke.test.js",
		"format": "prettier nodes credentials --write",
		"release": "n8n-node release",
		"prepublishOnly": "n8n-node prerelease"
	},
	"files": [
		"dist"
	],
	"n8n": {
		"n8nNodesApiVersion": 1,
		"strict": true,
		"credentials": [
			"dist/credentials/CobraCxmApi.credentials.js"
		],
		"nodes": [
			"dist/nodes/Cobra/Cobra.node.js",
			"dist/nodes/CobraTrigger/CobraTrigger.node.js"
		]
	},
	"devDependencies": {
		"@n8n/node-cli": "^0.39.3",
		"eslint": "9.39.4",
		"prettier": "3.8.3",
		"release-it": "20.2.0",
		"typescript": "5.9.3"
	},
	"peerDependencies": {
		"n8n-workflow": "*"
	}
}
